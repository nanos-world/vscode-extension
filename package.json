		"npm-check-updates": "^20.0.0",
		"prettier": "^3.8.1",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"@actions/core": "^1.10.1",
		"@actions/github": "^9.0.0",
